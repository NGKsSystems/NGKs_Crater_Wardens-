;
;   Hover:  x=600, 900, 3300, 3800
;   Drone:  (1000,380), (2600,360), (3650,360), (4550,360)
;   Turret: x=3000, 4450
;   Mine:   x=3150, 4600
;   PlatA:  x=1200, y=490  |  PlatB: x=1400, y=480  (jump-chain, 200px CC)
;   PlatC:  x=1750, y=470  |  PlatD: x=2100, y=490  (jump-chain, 350px CC each)
;   PlatE:  x=3600, y=490  (section 5 platform)
;   HazardGap1: (2600, 620) below Gap1
;   HazardGap2: (4200, 620) below Gap2
;   CP1: x=1400 | CP2: x=3200 | CP3: x=4400
;   Finish: x=5000
; ----------------------------------------------------------------

