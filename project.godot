; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but adventurous users can do it anyway.

[application]

config/name="NGKs Crater Wardens"
config/description="A low-spec, gameplay-first arcade rover shooter. 2.5D fixed-lane side scroller."
run/main_scene="res://scenes/root/game_root.tscn"
config/use_custom_user_dir=false
boot_splash/bg_color=Color(0.05, 0.05, 0.05, 1)

[display]

window/size/width=1280
window/size/height=720
window/size/resizable=true
window/stretch/mode="2d"
window/stretch/aspect="keep"

