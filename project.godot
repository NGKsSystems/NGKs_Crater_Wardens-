; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NGKs Crater Wardens"
config/description="A low-spec, gameplay-first arcade rover shooter. 2.5D fixed-lane side scroller."
run/main_scene="res://scenes/level/test_lane.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.05, 0.05, 0.05, 1)

[autoload]

GameStateManager="*res://scripts/systems/GameStateManager.gd"
PerformanceManager="*res://scripts/systems/PerformanceManager.gd"
ObjectPoolManager="*res://scripts/systems/ObjectPoolManager.gd"
ScoreManager="*res://scripts/systems/ScoreManager.gd"
VfxManager="*res://scripts/systems/VfxManager.gd"
AudioManager="*res://scripts/systems/AudioManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[input]

